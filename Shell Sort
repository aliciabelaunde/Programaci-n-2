#include <iostream>
using namespace std;

class ShellSort {
private:
    int arr[100];
    int n;

public:

    void ingresar() {
        cout << "Ingrese la cantidad de elementos: ";
        cin >> n;

        cout << "Ingrese los elementos:\n";
        for (int i = 0; i < n; i++) {
            cin >> arr[i];
        }
    }

    void mostrar() {
        for (int i = 0; i < n; i++) {
            cout << arr[i] << " ";
        }
        cout << endl;
    }

    void ordenar() {
        int paso = n / 2;

        while (paso > 0) {
            for (int i = paso; i < n; i++) {
                int j = i - paso;

                while (j >= 0) {
                    if (arr[j] > arr[j + paso]) {
                        int aux = arr[j];
                        arr[j] = arr[j + paso];
                        arr[j + paso] = aux;
                    }
                    j = j - paso;
                }
            }

            paso = paso / 2;
        }
    }
};

int main() {
    ShellSort s;

    s.ingresar();

    cout << "\nArreglo original:\n";
    s.mostrar();

    s.ordenar();

    cout << "\nArreglo ordenado:\n";
    s.mostrar();

    return 0;
}
