#include <iostream>
using namespace std;

class HeapSort {
private:
    int arr[8] = {7,2,1,6,4,5,3,8};
    int n = 8;

    void intercambiar(int &a, int &b) {
        int temp = a;
        a = b;
        b = temp;
    }

    void heapify(int n, int i) {
        int mayor = i;
        int izquierda = 2 * i + 1;
        int derecha = 2 * i + 2;

        if (izquierda < n && arr[izquierda] > arr[mayor])
            mayor = izquierda;

        if (derecha < n && arr[derecha] > arr[mayor])
            mayor = derecha;

        if (mayor != i) {
            intercambiar(arr[i], arr[mayor]);
            heapify(n, mayor);
        }
    }

public:
    void ordenar() {

        // construir el heap
        for (int i = n / 2 - 1; i >= 0; i--)
            heapify(n, i);

        // extraer elementos del heap
        for (int i = n - 1; i > 0; i--) {
            intercambiar(arr[0], arr[i]);
            heapify(i, 0);
        }
    }

    void mostrar() {
        for(int i = 0; i < n; i++)
            cout << arr[i] << " ";
        cout << endl;
    }
};

int main() {

    HeapSort hs;

    cout << "Arreglo original:\n";
    hs.mostrar();

    hs.ordenar();

    cout << "Arreglo ordenado:\n";
    hs.mostrar();

    return 0;
}
